# ─── Production environment for Docker deployment ────────────────────────────
# Copy this file to the server as .env.production
# docker-compose will pick it up automatically via --env-file or the default .env

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_STRONG_SECRET"

# ── AI Services ───────────────────────────────────────────────────────────────
# These services run on the HOST machine.
# host.docker.internal resolves to the host from inside the container.
OCR_API_URL="http://host.docker.internal:5050/ocr/file"
LLM_API_URL="http://host.docker.internal:11434/api/generate"
LLM_MODEL="gemma3:4b"
LLM_MAX_CHARS="4000"
AI_TIMEOUT_MS="55000"

# ── Storage ───────────────────────────────────────────────────────────────────
STORAGE_ROOT="storage/expenses"
