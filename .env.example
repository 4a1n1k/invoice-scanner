# Copy this file to .env and fill in your values.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
AUTH_SECRET="CHANGE_ME"

# ─── External AI Services ─────────────────────────────────────────────────────
OCR_API_URL="http://YOUR_SERVER:5050/ocr/file"
LLM_API_URL="http://YOUR_SERVER:11434/api/generate"
LLM_MODEL="gemma3:4b"
LLM_MAX_CHARS="4000"
AI_TIMEOUT_MS="55000"

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_ROOT="storage/expenses"

# Internal API key for Family War Room integration
INTERNAL_API_KEY="your-shared-secret-here"
