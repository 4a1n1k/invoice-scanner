# ─── Dependencies ────────────────────────────────────────────────────────────
/node_modules
/.pnp
.pnp.*

# ─── Next.js build output ────────────────────────────────────────────────────
/.next/
/out/
/build

# ─── Environment files ────────────────────────────────────────────────────────
# Never commit real secrets — only commit *.example files
.env
.env.local
.env.development
.env.production
.env*.local
# Allow example templates
!.env.example
!.env.production.example

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite DB has real user data — never commit
*.db
*.db-journal
*.db-shm
*.db-wal
# Allow prisma schema and migrations
!prisma/schema.prisma
!prisma/migrations/

# ─── Storage (uploaded invoice files) ────────────────────────────────────────
/storage/

# ─── Misc ────────────────────────────────────────────────────────────────────
.DS_Store
*.pem
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
/coverage
.vercel
*.tsbuildinfo
next-env.d.ts
/src/generated/prisma
start-dev.bat
